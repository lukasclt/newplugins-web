# Supabase / Postgres (usado pelo backend em produção e localmente)
# Estas variáveis já estão definidas no Vercel (Environment Variables).
# O arquivo .env local é ignorado pelo git e NÃO deve ser commitado.

POSTGRES_URL_NON_POOLING="postgres://postgres.<project>:<senha>@aws-1-sa-east-1.pooler.supabase.com:5432/postgres?sslmode=require"
POSTGRES_URL="postgres://postgres.<project>:<senha>@aws-1-sa-east-1.pooler.supabase.com:6543/postgres?sslmode=require&supa=base-pooler.x"

NEXT_PUBLIC_SUPABASE_URL="https://<project>.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxx"
SUPABASE_SERVICE_ROLE_KEY="eyJ..."
