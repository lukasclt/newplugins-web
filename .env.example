# Banco local (arquivo libSQL) — usado quando não há Turso configurado.
# Deixe em branco para usar o arquivo local server/turso.db
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Para usar Turso (Vercel/produção), crie um DB e cole os valores:
#   TURSO_DATABASE_URL=libsql://<seu-db>.turso.io
#   TURSO_AUTH_TOKEN=<seu-token>
